#!/usr/bin/env bash
# bell-bash installer — fzf-style, idempotent.
#
# Inserts a managed block bracketed by BEGIN_MARKER/END_MARKER into ~/.bashrc
# (and, in a later step, ~/.tmux.conf). Re-running replaces the block in
# place. --uninstall removes the block(s); the library directory is left
# intact so users can re-enable later.
#
# All prompts default to safe behavior:
#   --yes / --all means "use declared default", *not* "force yes" — so the
#   conflict-override prompt (default no) won't silently clobber user
#   settings even under automation.

set -Eeuo pipefail

REPO_DIR=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)

# Locations
#
# INSTALL_DIR defaults to the repo itself — the user clones bell-bash to
# wherever they want it (the README recommends ~/.bell-bash) and `./install`
# registers that location in their .bashrc. No copy step: updates are
# `cd $repo && git pull`, not `./install` reruns. BELL_BASH_HOME is still
# honoured for the legacy "copy elsewhere" case (we warn but don't block).
INSTALL_DIR=${BELL_BASH_HOME:-$REPO_DIR}
BASHRC=${BELL_BASH_BASHRC:-$HOME/.bashrc}
TMUXCONF=${BELL_BASH_TMUXCONF:-$HOME/.tmux.conf}
SKILL_LINK=${BELL_BASH_SKILL_LINK:-$HOME/.claude/skills/bell}

BEGIN_MARKER='# >>> bell-bash >>>'
END_MARKER='# <<< bell-bash <<<'

# Action + flags
ACTION='install'
ASSUME_YES=0
NO_BASHRC=0
NO_TMUX=0
NO_SKILL=0
THRESHOLD='5'
BELL_ACTION='other'
BACKENDS_FLAG=''
BACKENDS=''

# Colors
if [[ -t 1 ]]; then
    C_INFO=$'\033[36m'; C_WARN=$'\033[33m'; C_ERR=$'\033[31m'; C_RESET=$'\033[0m'
else
    C_INFO=''; C_WARN=''; C_ERR=''; C_RESET=''
fi
log()  { printf '%b[bell-bash]%b %s\n' "$C_INFO" "$C_RESET" "$*"; }
warn() { printf '%b[bell-bash]%b %s\n' "$C_WARN" "$C_RESET" "$*" >&2; }
err()  { printf '%b[bell-bash]%b %s\n' "$C_ERR"  "$C_RESET" "$*" >&2; }

usage() {
    cat <<'EOF'
Usage: ./install [OPTIONS]

  --uninstall              Remove the bell-bash block from rc files (backup
                           created). Library directory is preserved.
  --yes, --all             Non-interactive: use declared defaults for every
                           prompt. (Defaults are biased toward safe behavior —
                           e.g., the conflict-override prompt defaults to "no",
                           so user settings are never silently clobbered.)
  --no-bashrc              Don't touch ~/.bashrc.
  --no-tmux                Don't touch ~/.tmux.conf.
  --no-skill               Don't offer the Claude Code skill symlink.
  --threshold=N            Auto-trigger threshold in seconds (default 5).
  --bell-action=VAL        none|current|other|any for tmux (default other).
  --backends=LIST          Comma-separated backend list (default bel; skips
                           backend prompts when given).
  -h, --help               Show this help.
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --uninstall)        ACTION='uninstall' ;;
            --yes|--all)        ASSUME_YES=1 ;;
            --no-bashrc)        NO_BASHRC=1 ;;
            --no-tmux)          NO_TMUX=1 ;;
            --no-skill)         NO_SKILL=1 ;;
            --threshold=*)      THRESHOLD=${1#*=} ;;
            --bell-action=*)    BELL_ACTION=${1#*=} ;;
            --backends=*)       BACKENDS_FLAG=${1#*=} ;;
            -h|--help)          usage; exit 0 ;;
            *)                  err "unknown option: $1"; usage >&2; exit 2 ;;
        esac
        shift
    done
    case $BELL_ACTION in
        none|current|other|any) ;;
        *) err "invalid --bell-action: $BELL_ACTION (must be none|current|other|any)"; exit 2 ;;
    esac
}

# ask_yn PROMPT DEFAULT(yes|no)
#
# Returns 0 for yes, 1 for no. If --yes/--all is set or stdin is not a tty,
# returns based on DEFAULT — not based on "yes" — so safe defaults
# propagate to automated installs.
ask_yn() {
    local prompt=$1 default=$2
    if (( ASSUME_YES )) || ! [[ -t 0 ]]; then
        [[ $default == yes ]]
        return
    fi
    local hint='[y/N]'
    [[ $default == yes ]] && hint='[Y/n]'
    local ans=''
    read -rp "$prompt $hint " ans </dev/tty || true
    case ${ans,,} in
        y|yes) return 0 ;;
        n|no)  return 1 ;;
        '')    [[ $default == yes ]] ;;
        *)     [[ $default == yes ]] ;;
    esac
}

# remove_block FILE
#
# Strip the BEGIN..END block out of FILE. Trailing blank lines that would
# otherwise accumulate on each install are discarded by buffering blank
# lines and flushing them only when followed by non-blank content (PRD
# §11.7) — without this, every re-run would push a new blank line onto
# the end of the file.
remove_block() {
    local file=$1
    [[ -f "$file" ]] || return 0
    local tmp; tmp=$(mktemp)
    awk -v b="$BEGIN_MARKER" -v e="$END_MARKER" '
        $0 == b { skip = 1; next }
        skip {
            if ($0 == e) skip = 0
            next
        }
        /^[[:space:]]*$/ {
            buf = buf $0 "\n"
            next
        }
        {
            printf "%s", buf
            buf = ""
            print
        }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

# has_user_setting FILE PATTERN
# Returns 0 if PATTERN matches a line *outside* the bell-bash block. False
# positives from re-installs are suppressed by skipping lines inside our own
# managed region (PRD §11.8).
has_user_setting() {
    local file=$1 pattern=$2
    [[ -f "$file" ]] || return 1
    awk -v b="$BEGIN_MARKER" -v e="$END_MARKER" -v p="$pattern" '
        $0 == b { inside = 1; next }
        $0 == e { inside = 0; next }
        !inside && $0 ~ p { found = 1 }
        END { exit !found }
    ' "$file"
}

# comment_out_conflicts FILE PATTERN
# Prefix matching lines (outside our block, not already commented) with a
# `# [bell-bash] commented out:  ` marker so they're easy to find later.
comment_out_conflicts() {
    local file=$1 pattern=$2
    local tmp; tmp=$(mktemp)
    awk -v b="$BEGIN_MARKER" -v e="$END_MARKER" -v p="$pattern" '
        $0 == b { inside = 1 }
        $0 == e { inside = 0 }
        !inside && $0 ~ p && $0 !~ /^[[:space:]]*#/ {
            print "# [bell-bash] commented out:  " $0
            next
        }
        { print }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

backup_file() {
    local file=$1
    [[ -f "$file" ]] || return 0
    local backup="${file}.bell-bash.bak.$(date +%Y%m%d-%H%M%S)"
    cp -f "$file" "$backup"
    log "Backed up $file → $backup"
}

# get_block FILE — extract the current managed block (inclusive of markers)
# from FILE. Empty if no block present.
get_block() {
    local file=$1
    [[ -f "$file" ]] || return 0
    awk -v b="$BEGIN_MARKER" -v e="$END_MARKER" '
        $0 == b { inside = 1 }
        inside { print }
        $0 == e && inside { exit }
    ' "$file"
}

step_check_layout() {
    # The repo IS the install location — no copying. Verify the files we'll
    # be pointing bashrc/tmux at exist, then warn if the user has overridden
    # INSTALL_DIR to somewhere other than the repo (legacy "copy-elsewhere"
    # workflow), or if a stale v0.1-style copy sits at ~/.bell-bash.
    if [[ ! -f "$REPO_DIR/bell" ]]; then
        err "missing $REPO_DIR/bell"
        exit 1
    fi
    if [[ ! -x "$REPO_DIR/bin/bell-send" ]] && [[ ! -x "$REPO_DIR/bell-send" ]]; then
        err "missing $REPO_DIR/bin/bell-send (or $REPO_DIR/bell-send)"
        exit 1
    fi

    if [[ "$INSTALL_DIR" != "$REPO_DIR" ]]; then
        warn "BELL_BASH_HOME=$INSTALL_DIR differs from repo at $REPO_DIR."
        warn "bell-bash no longer copies files; bashrc/tmux will source from"
        warn "$INSTALL_DIR but the actual library lives at $REPO_DIR."
        warn "Recommended: clone (or move) the repo to $INSTALL_DIR and re-run."
    fi

    # Stale copy-style install from v0.1 — orphaned now that bashrc points
    # at the repo. Safe to delete but don't touch it unprompted.
    local legacy="$HOME/.bell-bash"
    if [[ -d "$legacy" \
       && ! -d "$legacy/.git" \
       && -f "$legacy/bell" \
       && "$legacy" != "$REPO_DIR" \
       && "$legacy" != "$INSTALL_DIR" ]]; then
        warn "Legacy copy-style install detected at $legacy"
        warn "It's no longer used; remove with: rm -rf $legacy"
    fi
}

step_choose_backends() {
    if [[ -n "$BACKENDS_FLAG" ]]; then
        BACKENDS=$BACKENDS_FLAG
        log "Using --backends=$BACKENDS"
        return
    fi
    local list='bel'
    if command -v notify-send >/dev/null 2>&1; then
        if ask_yn "Enable desktop toasts via notify-send?" yes; then
            list="${list},notify-send"
        fi
    fi
    if command -v noti >/dev/null 2>&1; then
        if ask_yn "Enable webhook alerts via 'noti send'?" no; then
            list="${list},webhook"
            if [[ -z "${NOTI_WEBHOOK:-}" ]]; then
                warn "NOTI_WEBHOOK is not set — webhook will silently no-op until you export it."
            fi
        fi
    fi
    BACKENDS=$list
}

build_bashrc_block() {
    printf '%s\n' "$BEGIN_MARKER"
    printf 'export BELL_BASH_THRESHOLD=%s\n' "$THRESHOLD"
    printf "export BELL_BASH_BACKENDS='%s'\n" "$BACKENDS"
    # Put bell-send on PATH so scripts and agents can call it directly.
    printf 'export PATH="%s/bin:$PATH"\n' "$INSTALL_DIR"
    printf 'source "%s/bell"\n' "$INSTALL_DIR"
    printf '%s\n' "$END_MARKER"
}

step_install_bashrc() {
    if (( NO_BASHRC )); then
        log "Skipping ~/.bashrc (--no-bashrc)"
        return
    fi
    if ! ask_yn "Install hook into $BASHRC?" yes; then
        log "Skipped $BASHRC"
        return
    fi

    local desired current
    desired=$(build_bashrc_block)
    current=$(get_block "$BASHRC")
    if [[ "$current" == "$desired" ]]; then
        log "$BASHRC already up to date"
        return
    fi

    backup_file "$BASHRC"
    remove_block "$BASHRC"
    {
        # If the file doesn't end in a newline, insert one before our block.
        if [[ -s "$BASHRC" ]] && [[ -n "$(tail -c 1 "$BASHRC" 2>/dev/null)" ]]; then
            printf '\n'
        fi
        printf '%s\n' "$desired"
    } >> "$BASHRC"
    log "Wrote bell-bash block to $BASHRC"
}

step_install_tmux() {
    if (( NO_TMUX )); then
        log "Skipping ~/.tmux.conf (--no-tmux)"
        return
    fi

    # Resolve the bell-action: if the user did not pass --bell-action and an
    # interactive tty is available, ask. The flag value (default 'other') is
    # used as the prompt's default and as the silent answer in --all mode.
    local action=$BELL_ACTION
    if [[ -f "$TMUXCONF" ]] && ! (( ASSUME_YES )) && [[ -t 0 ]]; then
        local input=''
        printf '[bell-bash] tmux bell-action (none|current|other|any) [%s]: ' "$action" >/dev/tty
        read -r input </dev/tty || input=''
        if [[ -n "$input" ]]; then
            case $input in
                none|current|other|any) action=$input ;;
                *) warn "invalid bell-action: $input — keeping $action" ;;
            esac
        fi
    fi

    if [[ -f "$TMUXCONF" ]] && ! ask_yn "Update $TMUXCONF?" yes; then
        log "Skipped $TMUXCONF"
        return
    fi

    local desired current
    desired=$(
        printf '%s\n' "$BEGIN_MARKER"
        sed "s/@BELL_ACTION@/${action}/g" "$REPO_DIR/bell.tmux.conf"
        printf '%s\n' "$END_MARKER"
    )
    current=$(get_block "$TMUXCONF")
    if [[ "$current" == "$desired" ]]; then
        log "$TMUXCONF already up to date (bell-action=$action)"
        return
    fi

    # Conflict detection — only lines outside any bell-bash block count.
    local conflict_pattern='monitor-bell[[:space:]]+off'
    local comment_conflicts=0
    if has_user_setting "$TMUXCONF" "$conflict_pattern"; then
        warn "Detected pre-existing 'monitor-bell off' in $TMUXCONF."
        warn "tmux uses last-write-wins, so our block at the end will override it."
        if ask_yn "Comment out the conflicting line so the override is obvious?" no; then
            comment_conflicts=1
        fi
    fi

    backup_file "$TMUXCONF"
    [[ -f "$TMUXCONF" ]] || touch "$TMUXCONF"

    if (( comment_conflicts )); then
        comment_out_conflicts "$TMUXCONF" "$conflict_pattern"
    fi
    remove_block "$TMUXCONF"
    {
        if [[ -s "$TMUXCONF" ]] && [[ -n "$(tail -c 1 "$TMUXCONF" 2>/dev/null)" ]]; then
            printf '\n'
        fi
        printf '%s\n' "$desired"
    } >> "$TMUXCONF"
    log "Wrote bell-bash block to $TMUXCONF (bell-action=$action)"

    if pgrep -x tmux >/dev/null 2>&1; then
        log "tmux is running — apply the new settings with:"
        log "  tmux source-file $TMUXCONF"
    fi
}

step_install_skill() {
    if (( NO_SKILL )); then
        log "Skipping Claude skill (--no-skill)"
        return
    fi
    local repo_skill="$REPO_DIR/skills/bell"
    if [[ ! -d "$repo_skill" ]]; then
        return
    fi
    if ! ask_yn "Link Claude Code skill into $SKILL_LINK?" yes; then
        log "Skipped Claude skill"
        return
    fi
    mkdir -p "$(dirname "$SKILL_LINK")"
    if [[ -L "$SKILL_LINK" ]]; then
        local cur
        cur=$(readlink -f "$SKILL_LINK" 2>/dev/null || true)
        if [[ "$cur" == "$(readlink -f "$repo_skill")" ]]; then
            log "Skill already linked: $SKILL_LINK → $repo_skill"
            return
        fi
        warn "$SKILL_LINK already points to $cur — leaving it alone"
        return
    fi
    if [[ -e "$SKILL_LINK" ]]; then
        warn "$SKILL_LINK exists and is not a symlink — leaving it alone"
        return
    fi
    ln -s "$repo_skill" "$SKILL_LINK"
    log "Linked $SKILL_LINK → $repo_skill"
}

do_uninstall() {
    local touched=0
    if [[ -f "$BASHRC" ]] && grep -qF "$BEGIN_MARKER" "$BASHRC"; then
        backup_file "$BASHRC"
        remove_block "$BASHRC"
        log "Removed bell-bash block from $BASHRC"
        touched=1
    fi
    if [[ -f "$TMUXCONF" ]] && grep -qF "$BEGIN_MARKER" "$TMUXCONF"; then
        backup_file "$TMUXCONF"
        remove_block "$TMUXCONF"
        log "Removed bell-bash block from $TMUXCONF"
        touched=1
    fi
    # Remove the skill symlink only when it resolves to *our* repo — don't
    # touch a link the user pointed elsewhere intentionally.
    if [[ -L "$SKILL_LINK" ]]; then
        local cur
        cur=$(readlink -f "$SKILL_LINK" 2>/dev/null || true)
        if [[ "$cur" == "$(readlink -f "$REPO_DIR/skills/bell" 2>/dev/null)" ]]; then
            rm -f "$SKILL_LINK"
            log "Removed Claude skill symlink $SKILL_LINK"
            touched=1
        fi
    fi
    if (( ! touched )); then
        log "Nothing to uninstall."
        return
    fi
    log "Library directory preserved at $INSTALL_DIR"
    log "Open a fresh shell to pick up the change."
}

step_summary() {
    cat <<EOF

[bell-bash] installed.

  threshold:  ${THRESHOLD}s
  backends:   ${BACKENDS}
  library:    ${INSTALL_DIR}/bell
  CLI:        ${INSTALL_DIR}/bin/bell-send

Updates: \`cd ${INSTALL_DIR} && git pull\` — no install rerun needed
unless you want to change threshold/backends/bell-action.

Open a new terminal (or 'source $BASHRC') and try:

  sleep 6                  # auto-trigger after threshold
  bell echo hi             # explicit wrapper
  false; bell              # explicit postfix
  bell_skip help           # skip-list reference

EOF
}

main() {
    parse_args "$@"
    if [[ ! -f "$REPO_DIR/bell.tmux.conf" ]]; then
        err "missing $REPO_DIR/bell.tmux.conf"
        exit 1
    fi
    if [[ $ACTION == uninstall ]]; then
        do_uninstall
        return
    fi
    step_check_layout
    step_choose_backends
    step_install_bashrc
    step_install_tmux
    step_install_skill
    step_summary
}

main "$@"

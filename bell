# bell-bash — long-running command notification system for interactive bash.
# SPDX-License-Identifier: BSD-3-Clause
# See PRD.md for the full spec.
#
# Sourced from ~/.bashrc; no shebang on purpose. Bash 5+ required.

# Bash version guard. EPOCHREALTIME (used by the auto-trigger hook) needs 5.0+.
if [[ -z "${BASH_VERSION:-}" ]] || (( ${BASH_VERSINFO[0]:-0} < 5 )); then
    return 0 2>/dev/null
fi

# Interactive shells only. Non-interactive contexts (agent bash_tool, scripts,
# `bash -c`, `ssh host cmd`) never evaluate this past here, so PS0 /
# PROMPT_COMMAND hooks and the `bell` function are absent there by design.
[[ $- != *i* ]] && return 0

# --- config ----------------------------------------------------------------

: "${BELL_BASH_THRESHOLD:=5}"        # seconds; auto-trigger threshold (float ok)
: "${BELL_BASH_BACKENDS:=bel}"       # comma-separated: bel,notify-send,webhook
: "${BELL_BASH_TIMEOUT_MS:=4000}"    # notify-send toast duration

# --- skip-list (auto-trigger only) -----------------------------------------
#
# Default list — interactive programs whose long runtime is normal and
# expected, so completion alerts would be noise. User can override entirely
# by pre-defining BELL_BASH_SKIP_LIST before sourcing this file.

if ! declare -p BELL_BASH_SKIP_LIST >/dev/null 2>&1; then
    BELL_BASH_SKIP_LIST=(
        # editors
        vi vim nvim emacs nano
        # pagers
        less more man tail journalctl
        # remote / multiplexers
        ssh mosh tmux screen
        # monitors
        top htop btop gdu watch
        # REPL / interactive
        gdb 'python3?' ipython node psql mysql sqlite3 claude
        # VCS — most git subcommands are quick and the pager-like ones
        # (log, diff, lg, df, …) all qualify as interactive output. Skip
        # the family wholesale; long network commands like `git clone`
        # that you want a ping for can be wrapped explicitly with `bell`.
        git
    )
fi

__bell_bash_rebuild_skip_regex() {
    if (( ${#BELL_BASH_SKIP_LIST[@]} == 0 )); then
        BELL_BASH_SKIP_REGEX=''
        return
    fi
    # IFS=| only inside the subshell so the parent's IFS is untouched.
    # Trailing ([[:space:]]|$) gives a word boundary so `vim` does not
    # match `vimdiff`. Optional `sudo ` prefix is recognised.
    BELL_BASH_SKIP_REGEX="^(sudo[[:space:]]+)?($(IFS='|'; echo "${BELL_BASH_SKIP_LIST[*]}"))([[:space:]]|$)"
}

__bell_bash_rebuild_skip_regex

# --- bell_skip: runtime control of the skip-list ---------------------------

bell_skip() {
    [[ $- != *i* ]] && return 0

    if (( $# == 0 )); then
        printf '%s\n' "${BELL_BASH_SKIP_LIST[@]}"
        return 0
    fi

    local sub=$1; shift
    case $sub in
        '+='|add)
            local p added=() existing
            for p in "$@"; do
                local present=0
                for existing in "${BELL_BASH_SKIP_LIST[@]}"; do
                    [[ "$existing" == "$p" ]] && { present=1; break; }
                done
                if (( ! present )); then
                    BELL_BASH_SKIP_LIST+=("$p")
                    added+=("$p")
                fi
            done
            __bell_bash_rebuild_skip_regex
            for p in "${added[@]}"; do printf '+ %s\n' "$p"; done
            ;;
        '-='|remove|rm)
            local p removed=() new existing found
            for p in "$@"; do
                new=()
                found=0
                for existing in "${BELL_BASH_SKIP_LIST[@]}"; do
                    if [[ "$existing" == "$p" ]]; then
                        found=1
                    else
                        new+=("$existing")
                    fi
                done
                BELL_BASH_SKIP_LIST=("${new[@]}")
                (( found )) && removed+=("$p")
            done
            __bell_bash_rebuild_skip_regex
            for p in "${removed[@]}"; do printf -- '- %s\n' "$p"; done
            ;;
        test)
            if (( $# == 0 )); then
                echo "bell_skip: 'test' needs a command" >&2
                return 2
            fi
            local cmdline="$*"
            if [[ -n "${BELL_BASH_SKIP_REGEX:-}" && "$cmdline" =~ $BELL_BASH_SKIP_REGEX ]]; then
                printf 'SKIP:   %s\n' "$cmdline"
            else
                printf 'NOTIFY: %s\n' "$cmdline"
            fi
            ;;
        help|-h|--help)
            cat <<'USAGE'
Usage: bell_skip [SUBCOMMAND] [PATTERN ...]

  bell_skip                       List current skip patterns.
  bell_skip += PATTERN ...        Add patterns (idempotent).
  bell_skip -= PATTERN ...        Remove patterns.
  bell_skip add PATTERN ...       Alias of +=.
  bell_skip remove PATTERN ...    Alias of -=.
  bell_skip rm PATTERN ...        Alias of -=.
  bell_skip test COMMAND ...      Dry-run: print SKIP or NOTIFY.
  bell_skip help                  Show this message.

Patterns are POSIX extended regular expressions, anchored at line start
with an optional `sudo ` prefix and a word-boundary tail. Use
[[:space:]]+ for multi-word patterns (e.g. 'git[[:space:]]+lz').
USAGE
            ;;
        *)
            echo "bell_skip: unknown subcommand: $sub (try 'bell_skip help')" >&2
            return 2
            ;;
    esac
}

# --- backends --------------------------------------------------------------

__bell_bash_backend_bel() {
    # Send BEL (0x07) to stderr so it isn't captured by $(...) substitutions.
    # The terminal emulator or tmux's monitor-bell turns this into a visible
    # or audible alert.
    printf '\a' >&2
}

__bell_bash_backend_notify_send() {
    command -v notify-send >/dev/null 2>&1 || return 0
    local exit_code=$1 title=$2 body=$3
    local urgency='normal'
    (( exit_code == 0 )) || urgency='critical'
    # Detached subshell — prompt latency stays at zero even if dbus is slow.
    ( notify-send -u "$urgency" -t "$BELL_BASH_TIMEOUT_MS" \
                  -- "$title" "$body" >/dev/null 2>&1 & disown ) 2>/dev/null
}

__bell_bash_backend_webhook() {
    command -v noti >/dev/null 2>&1 || return 0
    [[ -n "${NOTI_WEBHOOK:-}" ]] || return 0
    local exit_code=$1 cmd=$2 elapsed=$3
    local host=${HOSTNAME%%.*}
    local cwd=$PWD

    # noti embed renders as a coloured Discord/Slack card with title, desc,
    # and named fields — way more legible than the one-line `title — body`
    # that the previous `noti send` produced.
    local status_title color
    if (( exit_code == 0 )); then
        status_title='✅ done'
        color='#2ecc71'   # green
    else
        status_title="❌ failed (exit ${exit_code})"
        color='#e74c3c'   # red
    fi

    local args=( embed --title "$status_title" --color "$color" )
    # Put the command in the description as a code block — that's the line the
    # reader's eye lands on first.
    [[ -n $cmd ]] && args+=( --desc "$(printf '```\n%s\n```' "$cmd")" )
    [[ -n $elapsed ]] && args+=( --field Duration "$elapsed" )
    args+=( --field Host "$host" --field CWD "$cwd" )

    ( noti "${args[@]}" >/dev/null 2>&1 & disown ) 2>/dev/null
}

# --- dispatch --------------------------------------------------------------

__bell_bash_dispatch() {
    local exit_code=$1 title=$2 body=$3
    # Optional 4th arg overrides the env default. Empty = use env.
    local backends=${4:-}
    # Optional 5th/6th args are structured metadata for backends that can
    # use it (currently webhook). Other backends ignore them.
    local cmd=${5:-} elapsed=${6:-}
    [[ -z $backends ]] && backends=$BELL_BASH_BACKENDS
    local backend
    local IFS=','
    for backend in $backends; do
        backend=${backend// /}
        [[ -z $backend ]] && continue
        case $backend in
            bel)           __bell_bash_backend_bel "$exit_code" "$title" "$body" ;;
            notify-send)   __bell_bash_backend_notify_send "$exit_code" "$title" "$body" ;;
            webhook)       __bell_bash_backend_webhook "$exit_code" "$cmd" "$elapsed" ;;
            *)             : ;;
        esac
    done
}

# --- explicit trigger: bell ------------------------------------------------
#
# Wrapper:  bell [--backends=LIST] make -j8     → run, alert, return same code
# Postfix:  cmd1 && cmd2; bell [--backends=LIST]  → alert on previous $?
#
# --backends= overrides BELL_BASH_BACKENDS for this call only. Useful for
# `bell --backends=webhook ./long_build.sh` when you want the Slack ping but
# nothing local, or `bell --backends=notify-send` for a quiet desktop-only
# alert.
#
# Always fires regardless of skip-list — an explicit call means the user wants
# the notification.

bell() {
    # Capture $? as the very first thing — any other statement (including
    # the interactivity test below) clobbers it. This matters for postfix
    # mode where the caller relied on the previous command's exit code.
    local __bb_prev=$?
    [[ $- != *i* ]] && return "$__bb_prev"
    local backends_override=''
    while (( $# > 0 )); do
        case $1 in
            --backends=*) backends_override=${1#*=}; shift ;;
            --backends)   shift; backends_override=${1:-}; shift ;;
            --help|-h)
                cat <<'USAGE'
Usage: bell [--backends=LIST] [--] [COMMAND ...]

  bell COMMAND ...              Run COMMAND, alert on its exit, return same code.
  bell                          Alert on the previous command's $?.
  bell --backends=LIST [...]    Override BELL_BASH_BACKENDS for this call.
                                LIST is comma-separated: bel,notify-send,webhook.
USAGE
                return 0 ;;
            --)           shift; break ;;
            --*)          echo "bell: unknown option: $1 (try 'bell --help')" >&2; return 2 ;;
            *)            break ;;
        esac
    done
    local exit_code title body
    local host=${HOSTNAME%%.*}
    local elapsed_text='' dur_suffix=''

    if (( $# == 0 )); then
        exit_code=$__bb_prev
        # Postfix mode — borrow the preexec-set start time so the alert
        # shows duration on success *and* failure. When no preexec hook
        # was installed (no bash-preexec, no DEBUG trap) we just leave
        # elapsed empty and the webhook drops the Duration field.
        if [[ -n "${__bell_bash_start:-}" ]]; then
            elapsed_text=$(awk -v s="$__bell_bash_start" -v e="$EPOCHREALTIME" \
                          'BEGIN{ printf "%.2fs", e - s }')
        fi
        # Pull the line the user actually typed from history. It includes the
        # `; bell` (or `&& bell`, etc.) suffix that invoked us — that's an
        # unavoidable consequence of bash storing the whole prompt line as a
        # single history entry, and is still much more informative than the
        # literal string "previous command".
        local cmd
        cmd=$(HISTTIMEFORMAT='' history 1 2>/dev/null \
              | sed -E 's/^[[:space:]]*[0-9]+[[:space:]]+//')
        [[ -z $cmd ]] && cmd='previous command'
        [[ -n $elapsed_text ]] && dur_suffix=" (${elapsed_text})"
        if (( exit_code == 0 )); then
            title="✅ done${dur_suffix}"
        else
            title="❌ failed exit ${exit_code}${dur_suffix}"
        fi
        body=$(printf '%s\nhost: %s  cwd: %s' "$cmd" "$host" "$PWD")
        __bell_bash_dispatch "$exit_code" "$title" "$body" "$backends_override" "$cmd" "$elapsed_text"
        return "$exit_code"
    fi

    # Wrapper mode — measure locally so success and failure both carry it.
    local wrapped_cmd="$*"
    local __bb_w_start=$EPOCHREALTIME
    "$@"
    exit_code=$?
    elapsed_text=$(awk -v s="$__bb_w_start" -v e="$EPOCHREALTIME" \
                  'BEGIN{ printf "%.2fs", e - s }')
    dur_suffix=" (${elapsed_text})"
    if (( exit_code == 0 )); then
        title="✅ done${dur_suffix}"
    else
        title="❌ failed exit ${exit_code}${dur_suffix}"
    fi
    body=$(printf '%s\nhost: %s  cwd: %s' "$wrapped_cmd" "$host" "$PWD")
    __bell_bash_dispatch "$exit_code" "$title" "$body" "$backends_override" "$wrapped_cmd" "$elapsed_text"
    return "$exit_code"
}

# --- auto-trigger ----------------------------------------------------------
#
# Two hook strategies, selected at source time:
#
#   1. bash-preexec is present (starship, atuin, etc. pull it in):
#      register __bell_bash_preexec / __bell_bash_precmd into its hook
#      arrays. bash-preexec already owns DEBUG and PROMPT_COMMAND and
#      chains them cleanly across consumers, so any DEBUG trap we set
#      directly would be stomped on its next __bp_install — that's
#      exactly the regression that broke the auto-trigger in the wild.
#
#   2. No bash-preexec: install our own DEBUG trap + PROMPT_COMMAND
#      wrapper, tracking an "armed" flag so the first command per
#      prompt captures the start time while `cmd1 && cmd2` keeps a
#      single timing window.

__bell_bash_post() {
    local exit_code=$1
    [[ -z "${__bell_bash_start:-}" ]] && return 0
    local start=$__bell_bash_start
    local cmd=${__bell_bash_cmd_line:-}
    unset __bell_bash_start __bell_bash_cmd_line

    # bash-preexec hands us the typed command line directly; fall back to
    # `history 1` for the DEBUG-trap path where that's not available.
    if [[ -z $cmd ]]; then
        cmd=$(HISTTIMEFORMAT='' history 1 2>/dev/null \
              | sed -E 's/^[[:space:]]*[0-9]+[[:space:]]+//')
    fi

    local elapsed
    elapsed=$(awk -v s="$start" -v e="$EPOCHREALTIME" \
              'BEGIN{ printf "%.2f", e - s }')

    awk -v e="$elapsed" -v t="$BELL_BASH_THRESHOLD" \
        'BEGIN{ exit !(e + 0 >= t + 0) }' || return 0

    if [[ -n "${BELL_BASH_SKIP_REGEX:-}" && "$cmd" =~ $BELL_BASH_SKIP_REGEX ]]; then
        return 0
    fi

    local host=${HOSTNAME%%.*}
    local title body
    if (( exit_code == 0 )); then
        title="✅ done (${elapsed}s)"
    else
        title="❌ failed exit ${exit_code} (${elapsed}s)"
    fi
    body=$(printf '%s\nhost: %s  cwd: %s' "$cmd" "$host" "$PWD")
    __bell_bash_dispatch "$exit_code" "$title" "$body" "" "$cmd" "${elapsed}s"
}

# --- bash-preexec hooks ----------------------------------------------------

__bell_bash_preexec() {
    # bash-preexec invokes preexec_functions with the user's command line as $1.
    __bell_bash_start=$EPOCHREALTIME
    __bell_bash_cmd_line=$1
}

__bell_bash_precmd() {
    local exit_code=$?
    __bell_bash_post "$exit_code"
}

# --- direct DEBUG-trap hooks (fallback when no bash-preexec) --------------

__bell_bash_pre_debug() {
    [[ "$BASH_COMMAND" == "__bell_bash_prompt_command"* ]] && return
    [[ -n "${COMP_LINE:-}" ]] && return
    [[ -n "${READLINE_LINE:-}" ]] && return
    [[ -z "${__bell_bash_armed:-}" ]] && return
    __bell_bash_armed=
    __bell_bash_start=$EPOCHREALTIME
}

__bell_bash_prompt_command() {
    local exit_code=$?
    if [[ -n "${__bell_bash_prev_pc:-}" ]]; then
        (exit "$exit_code")
        eval "$__bell_bash_prev_pc"
    fi
    __bell_bash_post "$exit_code"
    __bell_bash_armed=on
    return "$exit_code"
}

# --- hook installation ----------------------------------------------------

if declare -p preexec_functions >/dev/null 2>&1 \
   && declare -p precmd_functions >/dev/null 2>&1; then
    # bash-preexec is available — register, never touch DEBUG/PROMPT_COMMAND.
    case " ${preexec_functions[*]:-} " in
        *" __bell_bash_preexec "*) ;;
        *) preexec_functions+=(__bell_bash_preexec) ;;
    esac
    case " ${precmd_functions[*]:-} " in
        *" __bell_bash_precmd "*) ;;
        *) precmd_functions+=(__bell_bash_precmd) ;;
    esac
else
    # No bash-preexec — own the hooks directly.
    if [[ "${PROMPT_COMMAND:-}" != *"__bell_bash_prompt_command"* ]]; then
        __bell_bash_prev_pc=${PROMPT_COMMAND:-}
        PROMPT_COMMAND='__bell_bash_prompt_command'
    fi
    trap '__bell_bash_pre_debug' DEBUG
fi
